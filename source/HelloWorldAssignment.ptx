<?xml version="1.0" encoding="UTF-8"?>
<!-- to build: pretext build HelloWorld-SCORM where this tag is identified in the "project.ptx" file -->
<pretext>
    <article xml:id="blah" xmlns:xi="http://www.w3.org/2001/XInclude">
        <title>ASCII-HelloWorld</title>
      <p>Please be patient while the ASCII assignment for "Hello World" is generated.  
            This may take a few seconds. Then respond to each question in hexadecimal. </p>
       <figure xml:id="fig-ASCII">
  <caption>ASCII Table</caption>
  <image source="images/ascii01.png" width="70%"/>
</figure>
         <exercise label="ASCII-HelloWorld" platform="doenetml">
  <title>ASCII Representation</title>
  <dynamic>
    <statement> 
       <interactive label="ASCII-HelloWorld" platform="doenetml">
        <slate surface="doenetml">  
          <xi:include href="doenet/ASCII-HelloWorld.doenetml" parse="text"/>
        </slate>  
      </interactive> 
    </statement>
  </dynamic>
  <static/>
</exercise>

    </article>
</pretext>